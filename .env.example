# ==================================================
# APPLICATION
# ==================================================

APP_NAME=DataOps AI Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ==================================================
# LOGGING
# ==================================================

LOG_LEVEL=INFO

# ==================================================
# AWS
# ==================================================

AWS_REGION=us-east-1
AWS_PROFILE=default

# ==================================================
# AMAZON BEDROCK
# ==================================================

BEDROCK_CHAT_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_ROUTER_MODEL=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_INFERENCE_PROFILE_ID=global.anthropic.claude-sonnet-4-6

# ==================================================
# S3
# ==================================================

S3_BUCKET=dataops-ai-assistant

# ==================================================
# OPENSEARCH
# ==================================================

OPENSEARCH_HOST=
OPENSEARCH_PORT=443
OPENSEARCH_INDEX=dataops-rag

# ==================================================
# DYNAMODB
# ==================================================

DYNAMODB_TABLE=conversation-memory

# ==================================================
# RAG
# ==================================================

TOP_K_RESULTS=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==================================================
# OBSERVABILITY
# ==================================================

ENABLE_TRACING=true
ENABLE_METRICS=true